{
  "name": "luminaris-server",
  "version": "1.0.0",
  "description": "Express API server for Luminaris Document Intelligence Platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts",
    "build": "npx prisma generate && tsc",
    "start": "node dist/server.js",
    "postinstall": "prisma generate",
    "clean": "if exist dist rmdir /s /q dist",
    "prebuild": "npm run clean",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset",
    "db:seed": "ts-node prisma/seed.ts",
    "docs:generate": "node ./scripts/generate-openapi.js",
    "accounting:reconcile": "node dist/jobs/accountingSyncReconcileCli.js",
    "lint": "eslint src",
    "test": "jest --forceExit",
    "test:leaks": "jest --detectOpenHandles --runInBand"
  },
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "@qdrant/js-client-rest": "^1.15.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "mammoth": "^1.11.0",
    "multer": "^2.0.2",
    "openai": "^4.104.0",
    "pdf-parse": "^1.1.1",
    "prisma": "^6.16.2",
    "puppeteer": "^25.3.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.39.4",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.61.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
